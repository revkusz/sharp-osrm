<!--
  NuGet.Config for integration tests.

  CI adds a 'local-nupkg' source pointing at the freshly packed .nupkg
  before running these tests. This config ensures ONLY that source is
  used — nuget.org must not override with a previously published version.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local-nupkg" value="." />
  </packageSources>
</configuration>
