{
    "version": 6,
    "configurePresets": [
        {
            "name": "macos-arm64",
            "displayName": "macOS ARM64 (Apple Silicon)",
            "description": "Build for macOS ARM64 using Conan + Ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "ENABLE_CONAN": "ON",
                "BUILD_PACKAGE": "OFF",
                "ENABLE_NODE_BINDINGS": "OFF",
                "ENABLE_LTO": "OFF"
            }
        },
        {
            "name": "macos-x64",
            "displayName": "macOS x86_64 (Intel)",
            "description": "Build for macOS x86_64 using Conan + Ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_OSX_ARCHITECTURES": "x86_64",
                "ENABLE_CONAN": "ON",
                "BUILD_PACKAGE": "OFF",
                "ENABLE_NODE_BINDINGS": "OFF",
                "ENABLE_LTO": "OFF"
            }
        },
        {
            "name": "linux-x64",
            "displayName": "Linux x86_64",
            "description": "Build for Linux x86_64 using Conan + Ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_CONAN": "ON",
                "BUILD_PACKAGE": "OFF",
                "ENABLE_NODE_BINDINGS": "OFF",
                "ENABLE_LTO": "OFF"
            }
        },
        {
            "name": "win-x64",
            "displayName": "Windows x64",
            "description": "Build for Windows x64 using Conan + Visual Studio",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_CONAN": "ON",
                "BUILD_PACKAGE": "OFF",
                "ENABLE_NODE_BINDINGS": "OFF",
                "ENABLE_LTO": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "macos-arm64",
            "configurePreset": "macos-arm64"
        },
        {
            "name": "macos-x64",
            "configurePreset": "macos-x64"
        },
        {
            "name": "linux-x64",
            "configurePreset": "linux-x64"
        },
        {
            "name": "win-x64",
            "configurePreset": "win-x64"
        }
    ]
}
